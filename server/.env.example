# Server .env.example
# Copy this to .env and fill in your values

# Express server port
PORT=3000

# PostgreSQL connection string (used by Prisma)
DATABASE_URL=postgresql://user:password@localhost:5432/learn_yoruba

# JWT signing secret — use a long random string (e.g. openssl rand -hex 32)
JWT_SECRET=replace-with-a-long-random-secret

# Comma-separated list of allowed CORS origins (no trailing slashes)
# e.g. ALLOWED_ORIGINS=https://your-app.web.app,https://www.yourdomain.com
ALLOWED_ORIGINS=http://localhost:5173
