// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  streak       Int @default(0)
  totalPoints  Int @default(0)
  level        Int @default(1)
  lastActiveAt DateTime @default(now())
  
  progress          UserProgress[]
  dailyGoals        DailyGoal[]
  schedules         LearningSchedule[]
  settings          UserSettings?
  flashcardReviews  FlashcardReview[]
  
  @@index([email])
  @@index([username])
}

model Lesson {
  id          String   @id @default(uuid())
  title       String
  description String
  category    String
  difficulty  String
  order       Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  phrases  Phrase[]
  progress UserProgress[]
  
  @@index([category])
  @@index([difficulty])
}

model Phrase {
  id       String @id @default(uuid())
  yoruba   String
  pronunciation String
  english  String
  audioUrl String?
  context  String?
  order    Int
  
  lessonId String
  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  
  @@index([lessonId])
}

model Vocabulary {
  id       String   @id @default(uuid())
  word     String
  pronunciation String
  meaning  String
  type     String
  examples String   // JSON string
  audioUrl String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  flashcardReviews FlashcardReview[]
  
  @@index([type])
}

model UserProgress {
  id              String   @id @default(uuid())
  userId          String
  lessonId        String
  completed       Boolean  @default(false)
  score           Int
  attempts        Int      @default(1)
  lastAttemptDate DateTime @default(now())
  
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  
  @@unique([userId, lessonId])
  @@index([userId])
  @@index([lessonId])
}

model DailyGoal {
  id               String   @id @default(uuid())
  userId           String
  date             DateTime @default(now())
  targetMinutes    Int      @default(15)
  completedMinutes Int      @default(0)
  targetLessons    Int      @default(3)
  completedLessons Int      @default(0)
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}

// ─── Learning Schedule ────────────────────────────────────────────────────────

model LearningSchedule {
  id        String   @id @default(uuid())
  userId    String
  dayOfWeek Int      // 0=Sunday … 6=Saturday
  startTime String   // "HH:MM" (24-hour)
  duration  Int      @default(30) // minutes
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── User Settings (learning style + technique preferences) ──────────────────

model UserSettings {
  id             String   @id @default(uuid())
  userId         String   @unique
  // "standard" | "military" | "story" | "immersion"
  learningStyle  String   @default("standard")
  // technique toggles
  flashcardMode  Boolean  @default(true)
  shadowingMode  Boolean  @default(false)
  mnemonicMode   Boolean  @default(false)
  storyMode      Boolean  @default(false)
  dailyReminders Boolean  @default(false)
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Flashcard / SRS Review ───────────────────────────────────────────────────

model FlashcardReview {
  id           String   @id @default(uuid())
  userId       String
  vocabularyId String
  // SM-2 algorithm fields
  easeFactor   Float    @default(2.5)
  interval     Int      @default(1)   // days until next review
  repetitions  Int      @default(0)
  nextReview   DateTime @default(now())
  lastReview   DateTime @default(now())
  createdAt    DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  vocabulary Vocabulary @relation(fields: [vocabularyId], references: [id], onDelete: Cascade)

  @@unique([userId, vocabularyId])
  @@index([userId])
  @@index([nextReview])
}
